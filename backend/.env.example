# PolicyLens backend environment variables
# Copy one of the .env.* files to .env or set ENVIRONMENT to load the correct file (e.g. ENVIRONMENT=development).
ENVIRONMENT=development
SECRET_KEY=supersecretchangeme
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
MONGO_URI=mongodb://mongodb:27017/policy_lens
REDIS_URL=redis://redis:6379
OLLAMA_URL=http://ollama:11434
OLLAMA_SUMMARY_MODEL=gemma3:4b-it-q4_K_M
OLLAMA_QA_MODEL=llama3.2:3b-instruct-q4_K_M
API_PREFIX=/api
